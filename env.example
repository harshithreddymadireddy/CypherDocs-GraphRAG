# Neo4j Database Connection Details
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Google Gemini API Key (Required for extraction and querying)
GEMINI_API_KEY=

# Model Configs
EMBEDDING_MODEL=gemini-embedding-2
GENERATIVE_MODEL=gemini-2.5-flash

# Ingestion Chunk Configs
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Server Configs
HOST=0.0.0.0
PORT=8000
